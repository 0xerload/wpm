# _wpm_webadmin_set_port PORT — patch baris "address" di dalam blok
# listener {} pertama pada admin_config.conf (WebAdmin console, default
# :7080), pertahankan host/bind address yang ada, hanya ganti nomor port.
# Backup timestamped sebelum menulis (§5.5).
_wpm_webadmin_set_port() {
  local new_port="$1"
  if [[ ! -f "$_WPM_WEBADMIN_CONF" ]]; then
    log_error "_wpm_webadmin_set_port: konfigurasi WebAdmin tidak ditemukan: ${_WPM_WEBADMIN_CONF}"
    return 1
  fi

  local ts backup
  ts="$(date -u +%Y%m%d%H%M%S 2>/dev/null)"
  backup="${_WPM_WEBADMIN_CONF}.bak-${ts}"
  if ! cp -p "$_WPM_WEBADMIN_CONF" "$backup"; then
    log_error "_wpm_webadmin_set_port: gagal membuat backup ${backup}"
    return 1
  fi
  log_action "WebAdmin config dibackup ke ${backup}"

  local tmp
  tmp="$(mktemp)" || { log_error "_wpm_webadmin_set_port: mktemp gagal"; return 1; }

  awk -v newport="$new_port" '
    function trim(s) { gsub(/^[ \t]+/, "", s); gsub(/[ \t]+$/, "", s); return s }
    BEGIN { in_l = 0 }
    {
      orig = $0
      t = trim(orig)
      n = split(t, w, /[ \t]+/)
      if (!in_l) {
        if (n >= 3 && w[1] == "listener" && w[n] == "{") { in_l = 1; print orig; next }
        print orig
        next
      }
      if (t == "}") { in_l = 0; print orig; next }
      if (n >= 2 && w[1] == "address") {
        host = w[2]
        sub(/:[0-9]+$/, "", host)
        match(orig, /^[ \t]*/); indent = substr(orig, RSTART, RLENGTH)
        printf("%s%-24s%s:%s\n", indent, "address", host, newport)
        next
      }
      print orig
    }
  ' "$_WPM_WEBADMIN_CONF" > "$tmp" && cat "$tmp" > "$_WPM_WEBADMIN_CONF"
  rm -f "$tmp"

  log_action "WebAdmin: port listener diganti ke ${new_port}"
  return 0
}

# _wpm_webadmin_reset_password USER NEWPASS — reset password WebAdmin.
# Password TIDAK diteruskan sebagai argumen CLI selama tool htpasswd yang
# terpasang mendukung "-i" (baca dari stdin) — fallback ke "-b" (password
# sebagai argumen, terlihat sesaat di ps aux) hanya bila "-i" gagal/tidak
# didukung, dicatat sebagai peringatan.
_wpm_webadmin_reset_password() {
  local user="$1" newpass="$2"

  if [[ ! -x "$_WPM_WEBADMIN_HTPASSWD_BIN" ]]; then
    log_error "_wpm_webadmin_reset_password: alat '${_WPM_WEBADMIN_HTPASSWD_BIN}' tidak ditemukan/tidak dapat dieksekusi."
    return 1
  fi
  mkdir -p "$(dirname "$_WPM_WEBADMIN_HTPASSWD_FILE")" 2>/dev/null

  local args=(-i)
  [[ -f "$_WPM_WEBADMIN_HTPASSWD_FILE" ]] || args+=(-c)
  args+=("$_WPM_WEBADMIN_HTPASSWD_FILE" "$user")

  if printf '%s\n' "$newpass" | "$_WPM_WEBADMIN_HTPASSWD_BIN" "${args[@]}" >>"$WPM_LOG_FILE" 2>&1; then
    log_action "WebAdmin: password user '${user}' berhasil direset (stdin, ${_WPM_WEBADMIN_HTPASSWD_BIN})"
    return 0
  fi

  log_warn "_wpm_webadmin_reset_password: opsi '-i' tampaknya tidak didukung, mencoba mode '-b'..."
  args=(-b)
  [[ -f "$_WPM_WEBADMIN_HTPASSWD_FILE" ]] || args+=(-c)
  args+=("$_WPM_WEBADMIN_HTPASSWD_FILE" "$user" "$newpass")
  if "$_WPM_WEBADMIN_HTPASSWD_BIN" "${args[@]}" >>"$WPM_LOG_FILE" 2>&1; then
    log_action "WebAdmin: password user '${user}' berhasil direset (-b, ${_WPM_WEBADMIN_HTPASSWD_BIN})"
    return 0
  fi

  log_error "_wpm_webadmin_reset_password: gagal mereset password WebAdmin untuk user '${user}'."
  return 1
}

# _wpm_ols_tuning_set KEY VALUE — upsert satu directive di dalam blok
# top-level `tuning { }` pada $OLS_CONF (brace-depth tracking, sama seperti
# idiom lib/ols.sh). Menambahkan blok tuning{} baru di akhir file bila
# belum ada sama sekali. Tidak backup/restart sendiri — dipanggil beberapa
# kali berturut-turut oleh menu_ws_tuning_preset yang membungkusnya dengan
# satu ols_backup_config + satu ols_graceful_restart di akhir.
_wpm_ols_tuning_set() {
  local key="$1" value="$2"
  if [[ ! -f "$OLS_CONF" ]]; then
    log_error "_wpm_ols_tuning_set: ${OLS_CONF} tidak ditemukan"
    return 1
  fi

  local tmp
  tmp="$(mktemp)" || { log_error "_wpm_ols_tuning_set: mktemp gagal"; return 1; }

  awk -v key="$key" -v value="$value" '
    function trim(s) { gsub(/^[ \t]+/, "", s); gsub(/[ \t]+$/, "", s); return s }
    BEGIN { in_t = 0; depth = 0; done = 0 }
    {
      orig = $0
      t = trim(orig)
      n = split(t, w, /[ \t]+/)

      if (!in_t) {
        if (n >= 2 && w[1] == "tuning" && w[n] == "{") { in_t = 1; depth = 1; print orig; next }
        print orig
        next
      }

      o = gsub(/\{/, "{", orig); c = gsub(/\}/, "}", orig)

      if (n >= 2 && w[1] == key && !done) {
        printf("  %-24s%s\n", key, value)
        done = 1
        depth += (o - c)
        if (depth <= 0) in_t = 0
        next
      }

      depth += (o - c)
      if (depth <= 0) {
        if (!done) { printf("  %-24s%s\n", key, value); done = 1 }
        in_t = 0
        print orig
        next
      }
      print orig
    }
    END {
      if (!done) {
        print "tuning  {"
        printf("  %-24s%s\n", key, value)
        print "}"
      }
    }
  ' "$OLS_CONF" > "$tmp" && cat "$tmp" > "$OLS_CONF"
  rm -f "$tmp"

  log_action "Web Server Settings: tuning.${key} = ${value}"
  return 0
}

