# --- toggle "alert monitor" via /etc/cron.d/wpm-monitor ---------------------

# _wpm_monitor_cron_status — echo "aktif" / "nonaktif" / "belum_terpasang".
_wpm_monitor_cron_status() {
  if [[ ! -f "$_WPM_CRON_FILE" ]]; then
    printf '%s\n' "belum_terpasang"
    return 0
  fi
  if grep -qE '^[^#[:space:]].*monitor\.sh' "$_WPM_CRON_FILE" 2>/dev/null; then
    printf '%s\n' "aktif"
  else
    printf '%s\n' "nonaktif"
  fi
}

# _wpm_monitor_cron_enable — pasang/aktifkan kembali baris cron 1-menit
# yang menjalankan $WPM_HOME/monitor.sh (§F-6a/§5.3).
_wpm_monitor_cron_enable() {
  local wpm_home="${WPM_HOME:-/usr/local/share/wpm}"
  mkdir -p "$(dirname "$_WPM_CRON_FILE")" 2>/dev/null

  if [[ ! -f "$_WPM_CRON_FILE" ]]; then
    {
      printf '# WPM — cron alert monitor (§F-6a). Kelola lewat: wpm > 6 > Nyalakan/matikan alert monitor.\n'
      printf '* * * * * root %s/monitor.sh >/dev/null 2>&1\n' "$wpm_home"
    } > "$_WPM_CRON_FILE"
  elif grep -q '^# DISABLED-BY-WPM: ' "$_WPM_CRON_FILE" 2>/dev/null; then
    sed -i 's/^# DISABLED-BY-WPM: //' "$_WPM_CRON_FILE"
  elif ! grep -qE '^\*.*monitor\.sh' "$_WPM_CRON_FILE" 2>/dev/null; then
    printf '* * * * * root %s/monitor.sh >/dev/null 2>&1\n' "$wpm_home" >> "$_WPM_CRON_FILE"
  fi
  chmod 644 "$_WPM_CRON_FILE" 2>/dev/null

  log_action "wpm: cron alert monitor diaktifkan (${_WPM_CRON_FILE})"
  return 0
}

# _wpm_monitor_cron_disable — komentari baris cron aktif (tanpa menghapus
# file, agar mudah diaktifkan kembali).
_wpm_monitor_cron_disable() {
  if [[ ! -f "$_WPM_CRON_FILE" ]]; then
    log_warn "Cron alert monitor belum terpasang, tidak ada yang dinonaktifkan."
    return 1
  fi
  sed -i -E 's/^([^#[:space:]].*monitor\.sh.*)$/# DISABLED-BY-WPM: \1/' "$_WPM_CRON_FILE"
  log_action "wpm: cron alert monitor dinonaktifkan (${_WPM_CRON_FILE})"
  return 0
}

# --- toggle "bot interaktif" via systemd -------------------------------------

# _wpm_bot_status — echo "aktif" / "nonaktif" / "belum_terpasang".
_wpm_bot_status() {
  if ! command -v systemctl >/dev/null 2>&1; then
    printf '%s\n' "belum_terpasang"
    return 0
  fi
  if ! systemctl list-unit-files --no-legend "$_WPM_BOT_SERVICE" 2>/dev/null | grep -q "$_WPM_BOT_SERVICE"; then
    printf '%s\n' "belum_terpasang"
    return 0
  fi
  if systemctl is-active --quiet "$_WPM_BOT_SERVICE" 2>/dev/null; then
    printf '%s\n' "aktif"
  else
    printf '%s\n' "nonaktif"
  fi
}

_wpm_bot_enable() {
  require_cmd systemctl
  if systemctl enable --now "$_WPM_BOT_SERVICE" >>"$WPM_LOG_FILE" 2>&1; then
    log_action "wpm: bot interaktif (${_WPM_BOT_SERVICE}) diaktifkan"
    return 0
  fi
  log_error "Gagal mengaktifkan ${_WPM_BOT_SERVICE} — lihat ${WPM_LOG_FILE}."
  return 1
}

_wpm_bot_disable() {
  require_cmd systemctl
  if systemctl disable --now "$_WPM_BOT_SERVICE" >>"$WPM_LOG_FILE" 2>&1; then
    log_action "wpm: bot interaktif (${_WPM_BOT_SERVICE}) dimatikan"
    return 0
  fi
  log_error "Gagal mematikan ${_WPM_BOT_SERVICE} — lihat ${WPM_LOG_FILE}."
  return 1
}

