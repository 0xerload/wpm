#!/usr/bin/env bash
#
# wpm — WPM (WordPress Manager untuk OpenLiteSpeed) — entry point utama.
#
# Menu terminal berwarna (NFR-05) yang mengorkestrasi seluruh lib/*.sh sesuai
# peta menu §4.1 PRD-WPM.md:
#
#   1) List Web Apps
#   2) Clone Web App
#   3) Kelola Web App        (PHP Settings, Redis ACL, Lihat Access Log,
#                              Retry SSL, Delete Web App)
#   4) Tools                 (Fix Ownership, Rebuild Web App Config,
#                              Clear Web App Cache)
#   5) Web Server Settings (OpenLiteSpeed)
#   6) Telegram & Monitoring  (setup wizard, threshold, toggle monitor/bot,
#                              tes notifikasi)
#   0) Keluar
#
# Konvensi (per WPM-CONTRACT.md):
#   - require_root dipanggil sekali di awal (setiap entry point WPM wajib
#     root, §7.3).
#   - acquire_lock (flock global, non-blocking) dipanggil sebelum jalur menu
#     mana pun yang MENGUBAH state (config OLS, registry, DB, Redis,
#     telegram.conf, cron, systemd). Listing murni (F-1) tidak mengunci.
#   - Semua operasi destruktif melewati confirm/confirm_typed (core.sh) —
#     wpm sendiri tidak pernah mengasumsikan non-interaktif.
#   - Tidak ada password yang diteruskan sebagai argumen CLI ke proses lain
#     bila bisa dihindari (lihat _wpm_webadmin_reset_password).
#
# Executable entry point → set -uo pipefail (BUKAN set -e): banyak jalur di
# sini sengaja menangani kegagalan lib function dengan lanjut ke menu
# berikutnya alih-alih mati begitu saja.

set -uo pipefail

# ---------------------------------------------------------------------------
# Sourcing lib/*.sh — mendukung dijalankan langsung dari checkout repo
# maupun dari lokasi terpasang ($WPM_HOME, default /usr/local/share/wpm).
# ---------------------------------------------------------------------------

_WPM_BIN_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" >/dev/null 2>&1 && pwd)"
if [[ -f "${_WPM_BIN_DIR}/lib/core.sh" ]]; then
  _WPM_LIB_DIR="${_WPM_BIN_DIR}/lib"
else
  _WPM_LIB_DIR="${WPM_HOME:-/usr/local/share/wpm}/lib"
fi
unset _WPM_BIN_DIR

for _wpm_lib_name in core ols redis ssl php tools clone telegram; do
  _wpm_lib_file="${_WPM_LIB_DIR}/${_wpm_lib_name}.sh"
  if [[ ! -f "$_wpm_lib_file" ]]; then
    echo "wpm: file library tidak ditemukan: ${_wpm_lib_file}" >&2
    echo "wpm: pastikan WPM terpasang dengan benar (jalankan ulang install.sh)." >&2
    exit 1
  fi
  # shellcheck source=/dev/null
  source "$_wpm_lib_file"
done
unset _wpm_lib_name _wpm_lib_file _WPM_LIB_DIR

# ---------------------------------------------------------------------------
# Konstanta khusus wpm (bukan bagian dari lib/core.sh — dipakai lokal saja
# oleh submenu Telegram & Monitoring / Web Server Settings di file ini).
# ---------------------------------------------------------------------------

readonly _WPM_CRON_FILE="/etc/cron.d/wpm-monitor"
readonly _WPM_BOT_SERVICE="wpm-bot.service"
readonly _WPM_WEBADMIN_CONF="${OLS_HOME}/admin/conf/admin_config.conf"
readonly _WPM_WEBADMIN_HTPASSWD_FILE="${OLS_HOME}/admin/conf/htpasswd"
readonly _WPM_WEBADMIN_HTPASSWD_BIN="${OLS_HOME}/admin/misc/htpasswd"

# ============================================================================
# Helper UI generik
# ============================================================================

# _wpm_banner — header menu utama (NFR-05: menu angka + warna ANSI).
_wpm_banner() {
  printf '\n%s%s╔══════════════════════════════════╗%s\n' "$C_BOLD" "$C_CYAN" "$C_RESET"
  printf '%s%s║   WPM — WordPress Manager (OLS)   ║%s\n' "$C_BOLD" "$C_CYAN" "$C_RESET"
  printf '%s%s╚══════════════════════════════════╝%s\n' "$C_BOLD" "$C_CYAN" "$C_RESET"
  printf '%sversi %s · %s%s\n' "$C_DIM" "$WPM_VERSION" "$(hostname 2>/dev/null || echo '-')" "$C_RESET"
}

# _wpm_section HEADER — cetak header sub-bagian yang konsisten.
_wpm_section() {
  printf '\n%s=== %s ===%s\n' "$C_BOLD" "$1" "$C_RESET"
}

# _wpm_menu_choice DEFAULT — baca pilihan menu, echo pada stdout.
_wpm_menu_choice() {
  prompt_default "Pilih menu" "${1:-0}"
}

# _wpm_prompt_number LABEL DEFAULT — ulangi sampai input berupa angka
# (boleh desimal, untuk kelipatan load average). Echo hasil pada stdout.
_wpm_prompt_number() {
  local label="$1" default="$2" val
  while true; do
    val="$(prompt_default "$label" "$default")"
    if [[ "$val" =~ ^[0-9]+(\.[0-9]+)?$ ]]; then
      printf '%s\n' "$val"
      return 0
    fi
    printf '%sMasukkan angka yang valid.%s\n' "$C_RED" "$C_RESET" >&2
  done
}

# _wpm_choose_app LABEL — tampilkan daftar app terdaftar (nomor + domain),
# minta pengguna memilih satu, echo nama app pada stdout. Return 1 (tanpa
# echo apa pun) bila pengguna memilih "0) Kembali" atau belum ada app sama
# sekali. Semua prompt/listing ditulis ke stderr agar aman dipakai sebagai
# app="$(_wpm_choose_app ...)".
_wpm_choose_app() {
  local label="${1:-Pilih app}"
  local -a apps=()
  mapfile -t apps < <(list_apps)

  if (( ${#apps[@]} == 0 )); then
    printf '%sBelum ada web app terdaftar. Clone atau import vhost dulu.%s\n' "$C_YELLOW" "$C_RESET" >&2
    return 1
  fi

  printf '\n%s%s:%s\n' "$C_BOLD" "$label" "$C_RESET" >&2
  local i
  for i in "${!apps[@]}"; do
    printf '  %2d) %-24s %s\n' "$((i + 1))" "${apps[$i]}" "$(app_get "${apps[$i]}" DOMAIN)" >&2
  done
  printf '   0) Kembali\n' >&2

  local sel
  while true; do
    sel="$(prompt_default "Nomor app" "0")"
    if [[ "$sel" == "0" ]]; then
      return 1
    fi
    if [[ "$sel" =~ ^[0-9]+$ ]] && (( sel >= 1 && sel <= ${#apps[@]} )); then
      printf '%s\n' "${apps[$((sel - 1))]}"
      return 0
    fi
    printf '%sPilihan tidak valid.%s\n' "$C_RED" "$C_RESET" >&2
  done
}

# ============================================================================
# F-1 — List Web Apps
# ============================================================================

# menu_list_web_apps — FR-01/FR-02: tabel gabungan registry + vhost manual
# yang belum dikelola (via ols_parse_vhosts), dengan opsi import. Tidak
# mengunci (read-only).
menu_list_web_apps() {
  _wpm_section "List Web Apps"

  local -a apps=()
  mapfile -t apps < <(list_apps)

  if (( ${#apps[@]} == 0 )); then
    printf '%sBelum ada web app terdaftar.%s\n' "$C_YELLOW" "$C_RESET"
  else
    printf '%s%-18s %-26s %-30s %-14s %-9s %-7s %8s%s\n' \
      "$C_BOLD" "Nama" "Domain" "Docroot" "Database" "PHP" "SSL" "Disk" "$C_RESET"

    local app domain docroot db php ssl_status ssl_disp size vh_root
    for app in "${apps[@]}"; do
      domain="$(app_get "$app" DOMAIN)";   [[ -z "$domain" ]] && domain="-"
      docroot="$(app_get "$app" DOCROOT)"; [[ -z "$docroot" ]] && docroot="-"
      db="$(app_get "$app" DB_NAME)";      [[ -z "$db" ]] && db="-"
      php="$(app_get "$app" PHP_HANDLER)"; [[ -z "$php" ]] && php="-"
      ssl_status="$(app_get "$app" SSL_STATUS)"
      case "$ssl_status" in
        active) ssl_disp="aktif" ;;
        failed) ssl_disp="gagal" ;;
        "" | none) ssl_disp="-" ;;
        *) ssl_disp="$ssl_status" ;;
      esac
      vh_root="$(app_get "$app" VH_ROOT)"
      size="-"
      [[ -n "$vh_root" && -d "$vh_root" ]] && size="$(du -sh -- "$vh_root" 2>/dev/null | cut -f1)"
      [[ -z "$size" ]] && size="-"

      printf '%-18s %-26s %-30s %-14s %-9s %-7s %8s\n' \
        "$app" "$domain" "$docroot" "$db" "$php" "$ssl_disp" "$size"
    done
  fi

  # FR-02: deteksi vhost yang dibuat manual (belum ada di registry WPM).
  local -a un_names=() un_vhroots=() un_confs=()
  if [[ -f "$OLS_CONF" ]]; then
    local name vhroot conf
    while IFS=$'\t' read -r name vhroot conf; do
      [[ -z "$name" ]] && continue
      if ! app_exists "$name"; then
        un_names+=("$name")
        un_vhroots+=("$vhroot")
        un_confs+=("$conf")
      fi
    done < <(ols_parse_vhosts)
  fi

  if (( ${#un_names[@]} > 0 )); then
    printf '\n%sVhost belum terkelola (dibuat manual, belum ada di registry WPM):%s\n' "$C_YELLOW" "$C_RESET"
    local i
    for i in "${!un_names[@]}"; do
      printf '  %2d) %-24s vhRoot=%s\n' "$((i + 1))" "${un_names[$i]}" "${un_vhroots[$i]}"
    done

    if confirm "Import salah satu vhost di atas ke registry WPM sekarang?" "default_n"; then
      local sel
      while true; do
        sel="$(prompt_default "Nomor vhost yang akan diimport (0=batal)" "0")"
        [[ "$sel" == "0" ]] && break
        if [[ "$sel" =~ ^[0-9]+$ ]] && (( sel >= 1 && sel <= ${#un_names[@]} )); then
          acquire_lock
          if ols_import_vhost "${un_names[$((sel - 1))]}" "${un_vhroots[$((sel - 1))]}" "${un_confs[$((sel - 1))]}"; then
            log_info "Vhost '${un_names[$((sel - 1))]}' berhasil diimport ke registry — kini bisa dipakai sebagai sumber clone."
          else
            log_error "Gagal mengimport vhost '${un_names[$((sel - 1))]}'. Lihat ${WPM_LOG_FILE}."
          fi
          break
        fi
        printf '%sPilihan tidak valid.%s\n' "$C_RED" "$C_RESET" >&2
      done
    fi
  fi

  pause_enter
}

# ============================================================================
# F-3 — Kelola Web App
# ============================================================================

# menu_manage_web_app — pilih app lalu tampilkan submenu §4.1 "Kelola Web
# App" (PHP Settings / Redis ACL / Lihat Access Log / Retry SSL / Delete).
menu_manage_web_app() {
  while true; do
    local app
    app="$(_wpm_choose_app "Pilih app untuk dikelola")" || return 0
    _wpm_manage_app_submenu "$app"
  done
}

_wpm_manage_app_submenu() {
  local app="$1"
  while true; do
    if ! app_exists "$app"; then
      return 0
    fi
    _wpm_section "Kelola Web App: ${app}"
    printf '  Domain : %s\n' "$(app_get "$app" DOMAIN)"
    printf '  SSL    : %s\n' "$(app_get "$app" SSL_STATUS)"
    printf '  PHP    : %s\n\n' "$(app_get "$app" PHP_HANDLER)"
    printf ' 1) PHP Settings\n'
    printf ' 2) Redis ACL\n'
    printf ' 3) Lihat Access Log\n'
    printf ' 4) Retry SSL\n'
    printf ' 5) Delete Web App\n'
    printf ' 0) Kembali ke daftar app\n'

    local c
    c="$(_wpm_menu_choice 0)"
    case "$c" in
      1) acquire_lock; menu_php_settings "$app" ;;
      2) acquire_lock; menu_redis_acl "$app" ;;
      3) menu_access_log "$app" ;;
      4) acquire_lock; menu_retry_ssl "$app" ;;
      5) acquire_lock; menu_delete_app "$app" ;;
      0) return 0 ;;
      *) printf '%sPilihan tidak valid.%s\n' "$C_RED" "$C_RESET" ;;
    esac
  done
}

# --- F-3a · PHP Settings -----------------------------------------------------

menu_php_settings() {
  local app="$1"
  while true; do
    if ! app_exists "$app"; then return 0; fi
    _wpm_section "PHP Settings: ${app}"
    printf '  memory_limit        : %s\n' "$(php_ini_get "$app" memory_limit)"
    printf '  upload_max_filesize : %s\n' "$(php_ini_get "$app" upload_max_filesize)"
    printf '  post_max_size       : %s\n' "$(php_ini_get "$app" post_max_size)"
    printf '  max_execution_time  : %s\n' "$(php_ini_get "$app" max_execution_time)"
    printf '  max_input_vars      : %s\n' "$(php_ini_get "$app" max_input_vars)"
    printf '  Versi PHP saat ini  : %s\n\n' "$(app_get "$app" PHP_HANDLER)"
    printf ' 1) Terapkan preset (Low/Normal/High)\n'
    printf ' 2) Atur manual (5 parameter)\n'
    printf ' 3) Ganti versi PHP (lsphp)\n'
    printf ' 0) Kembali\n'

    local c
    c="$(_wpm_menu_choice 0)"
    case "$c" in
      1)
        printf '  1) Low    (memory 128M, upload/post 32M/34M, exec 60s)\n'
        printf '  2) Normal (memory 256M, upload/post 64M/68M, exec 120s)\n'
        printf '  3) High   (memory 512M, upload/post 128M/136M, exec 300s)\n'
        local p preset_name=""
        p="$(prompt_default "Pilih preset" "1")"
        case "$p" in
          1) preset_name="low" ;;
          2) preset_name="normal" ;;
          3) preset_name="high" ;;
          *) printf '%sPilihan tidak valid.%s\n' "$C_RED" "$C_RESET" ;;
        esac
        if [[ -n "$preset_name" ]] && confirm "Terapkan preset '${preset_name}' untuk '${app}'? (OLS akan direstart graceful)" "default_y"; then
          php_apply_preset "$app" "$preset_name"
        fi
        ;;
      2)
        local mem up post ex iv
        mem="$(prompt_default "memory_limit" "$(php_ini_get "$app" memory_limit)")"
        up="$(prompt_default "upload_max_filesize" "$(php_ini_get "$app" upload_max_filesize)")"
        post="$(prompt_default "post_max_size" "$(php_ini_get "$app" post_max_size)")"
        ex="$(prompt_default "max_execution_time" "$(php_ini_get "$app" max_execution_time)")"
        iv="$(prompt_default "max_input_vars" "$(php_ini_get "$app" max_input_vars)")"
        if confirm "Simpan pengaturan PHP manual di atas untuk '${app}'? (OLS akan direstart graceful)" "default_y"; then
          php_ini_set_all "$app" \
            memory_limit="$mem" upload_max_filesize="$up" post_max_size="$post" \
            max_execution_time="$ex" max_input_vars="$iv"
        fi
        ;;
      3)
        local -a versions=()
        mapfile -t versions < <(php_list_installed_versions)
        if (( ${#versions[@]} == 0 )); then
          printf '%sTidak ditemukan versi lsphp terpasang di %s.%s\n' "$C_YELLOW" "$OLS_HOME" "$C_RESET"
        else
          local i
          for i in "${!versions[@]}"; do
            printf '  %d) %s\n' "$((i + 1))" "${versions[$i]}"
          done
          local sel
          sel="$(prompt_default "Pilih versi PHP" "1")"
          if [[ "$sel" =~ ^[0-9]+$ ]] && (( sel >= 1 && sel <= ${#versions[@]} )); then
            local handler="${versions[$((sel - 1))]}"
            if confirm "Ganti versi PHP '${app}' ke '${handler}'? (OLS akan direstart graceful)" "default_y"; then
              php_set_version "$app" "$handler"
            fi
          else
            printf '%sPilihan tidak valid.%s\n' "$C_RED" "$C_RESET"
          fi
        fi
        ;;
      0) return 0 ;;
      *) printf '%sPilihan tidak valid.%s\n' "$C_RED" "$C_RESET" ;;
    esac
    pause_enter
  done
}

# --- F-3b · Redis ACL --------------------------------------------------------

# _wpm_redis_user_status USER — echo "aktif"/"nonaktif"/"tidak ditemukan"/"-"
# berdasarkan flag on/off pada baris user di $REDIS_ACL_FILE.
_wpm_redis_user_status() {
  local user="$1"
  if [[ -z "$user" || ! -f "$REDIS_ACL_FILE" ]]; then
    printf '%s\n' "-"
    return 0
  fi
  local line state
  line="$(awk -v u="$user" '$1=="user" && $2==u { print; exit }' "$REDIS_ACL_FILE" 2>/dev/null)"
  if [[ -z "$line" ]]; then
    printf '%s\n' "tidak ditemukan"
    return 0
  fi
  state="$(awk '{print $3}' <<<"$line")"
  case "$state" in
    on) printf '%s\n' "aktif" ;;
    off) printf '%s\n' "nonaktif" ;;
    *) printf '%s\n' "$state" ;;
  esac
}

menu_redis_acl() {
  local app="$1"
  while true; do
    if ! app_exists "$app"; then return 0; fi
    local user pass dbid status
    user="$(app_get "$app" REDIS_USER)"
    pass="$(app_get "$app" REDIS_PASS)"
    dbid="$(app_get "$app" REDIS_DB_ID)"
    status="$(_wpm_redis_user_status "$user")"

    _wpm_section "Redis ACL: ${app}"
    printf '  User       : %s\n' "${user:--}"
    printf '  DB ID      : %s\n' "${dbid:--}"
    printf '  Prefix key : %s:*\n' "$app"
    printf '  Status ACL : %s\n\n' "$status"
    printf ' 1) Lihat kredensial lengkap\n'
    printf ' 2) Regenerate password\n'
    printf ' 3) Enable user\n'
    printf ' 4) Disable user\n'
    printf ' 0) Kembali\n'

    local c
    c="$(_wpm_menu_choice 0)"
    case "$c" in
      1)
        if [[ -z "$user" ]]; then
          printf '%sApp ini belum memiliki kredensial Redis (kemungkinan hasil import manual).%s\n' "$C_YELLOW" "$C_RESET"
        else
          printf '\n%sKredensial Redis — %s%s\n' "$C_YELLOW" "$app" "$C_RESET"
          printf '  Host     : 127.0.0.1:6379\n'
          printf '  User     : %s\n' "$user"
          printf '  Password : %s\n' "$pass"
          printf '  DB ID    : %s\n' "$dbid"
        fi
        ;;
      2)
        if [[ -z "$user" ]]; then
          printf '%sTidak ada user Redis untuk app ini.%s\n' "$C_YELLOW" "$C_RESET"
        else
          redis_regen_password "$app"
        fi
        ;;
      3)
        if [[ -z "$user" ]]; then
          printf '%sTidak ada user Redis untuk app ini.%s\n' "$C_YELLOW" "$C_RESET"
        else
          redis_set_enabled "$app" on
        fi
        ;;
      4)
        if [[ -z "$user" ]]; then
          printf '%sTidak ada user Redis untuk app ini.%s\n' "$C_YELLOW" "$C_RESET"
        else
          redis_set_enabled "$app" off
        fi
        ;;
      0) return 0 ;;
      *) printf '%sPilihan tidak valid.%s\n' "$C_RED" "$C_RESET" ;;
    esac
    pause_enter
  done
}

# --- F-3c · Lihat Access Log --------------------------------------------------

# menu_access_log APP — viewer §F-3c: tail live, Top 10 IP, Top 10 URL,
# ringkasan status code, semua berbasis awk/sort/uniq (beban nyaris nol).
# Read-only — tidak memerlukan acquire_lock.
menu_access_log() {
  local app="$1"
  local vh_root logfile
  vh_root="$(app_get "$app" VH_ROOT)"
  logfile="${vh_root}/logs/access.log"

  while true; do
    if ! app_exists "$app"; then return 0; fi
    _wpm_section "Lihat Access Log: ${app}"
    printf '  File: %s\n' "$logfile"
    if [[ ! -f "$logfile" ]]; then
      printf '%s  (File log belum ada / belum ada traffic tercatat)%s\n' "$C_YELLOW" "$C_RESET"
    fi
    printf '\n 1) Tail log (live, Ctrl+C untuk kembali ke menu)\n'
    printf ' 2) Top 10 IP\n'
    printf ' 3) Top 10 URL\n'
    printf ' 4) Ringkasan status code\n'
    printf ' 0) Kembali\n'

    local c
    c="$(_wpm_menu_choice 0)"
    case "$c" in
      1)
        if [[ -f "$logfile" ]]; then
          printf '%sMenampilkan log secara live. Tekan Ctrl+C untuk kembali ke menu.%s\n' "$C_YELLOW" "$C_RESET"
          # Isolasi SIGINT di subshell sendiri: Ctrl+C hanya menghentikan
          # `tail -f` ini, tidak mematikan seluruh proses wpm (trap lock di
          # core.sh tetap utuh karena tidak ada exit di shell utama).
          ( trap 'exit 0' INT TERM; tail -n 50 -f -- "$logfile" )
        else
          printf '%sFile log belum ada.%s\n' "$C_YELLOW" "$C_RESET"
        fi
        ;;
      2)
        if [[ -f "$logfile" ]]; then
          printf '\n%sTop 10 IP (berdasar jumlah request):%s\n' "$C_BOLD" "$C_RESET"
          awk '{print $1}' -- "$logfile" 2>/dev/null \
            | sort | uniq -c | sort -rn | head -n 10 \
            | awk '{printf "  %6d  %s\n", $1, $2}'
        else
          printf '%sFile log belum ada.%s\n' "$C_YELLOW" "$C_RESET"
        fi
        ;;
      3)
        if [[ -f "$logfile" ]]; then
          printf '\n%sTop 10 URL (berdasar jumlah request):%s\n' "$C_BOLD" "$C_RESET"
          # Format log gaya Combined: IP - - [date] "METHOD /path HTTP/x" status size "ref" "agent"
          # Split by " memberi field ke-2 = "METHOD /path HTTP/x".
          awk -F'"' '{print $2}' -- "$logfile" 2>/dev/null \
            | awk '{print $2}' \
            | sort | uniq -c | sort -rn | head -n 10 \
            | awk '{printf "  %6d  %s\n", $1, $2}'
        else
          printf '%sFile log belum ada.%s\n' "$C_YELLOW" "$C_RESET"
        fi
        ;;
      4)
        if [[ -f "$logfile" ]]; then
          printf '\n%sRingkasan status code:%s\n' "$C_BOLD" "$C_RESET"
          # Field ke-3 hasil split by " adalah " STATUS SIZE " — token
          # pertamanya (setelah trim) adalah kode status HTTP.
          awk -F'"' '{print $3}' -- "$logfile" 2>/dev/null \
            | awk '{print $1}' \
            | sort | uniq -c | sort -rn \
            | awk '{printf "  %6d  %s\n", $1, $2}'
        else
          printf '%sFile log belum ada.%s\n' "$C_YELLOW" "$C_RESET"
        fi
        ;;
      0) return 0 ;;
      *) printf '%sPilihan tidak valid.%s\n' "$C_RED" "$C_RESET" ;;
    esac
    pause_enter
  done
}

# --- F-3d · Retry SSL ---------------------------------------------------------

menu_retry_ssl() {
  local app="$1"
  local status
  status="$(app_get "$app" SSL_STATUS)"
  _wpm_section "Retry SSL: ${app}"
  printf '  Status SSL saat ini: %s\n' "${status:-none}"
  if confirm "Coba terbitkan/pasang ulang SSL untuk '${app}' sekarang?" "default_y"; then
    ssl_retry "$app"
  else
    log_info "Retry SSL '${app}' dibatalkan."
  fi
  pause_enter
}

# --- F-3e · Delete Web App -----------------------------------------------------

menu_delete_app() {
  local app="$1"
  app_delete "$app"
  pause_enter
}

# ============================================================================
# F-4 — Tools
# ============================================================================

menu_tools() {
  while true; do
    local app
    app="$(_wpm_choose_app "Pilih app untuk Tools")" || return 0
    _wpm_tools_submenu "$app"
  done
}

_wpm_tools_submenu() {
  local app="$1"
  while true; do
    if ! app_exists "$app"; then return 0; fi
    _wpm_section "Tools: ${app}"
    printf ' 1) Fix Ownership\n'
    printf ' 2) Rebuild Web App Config\n'
    printf ' 3) Clear Web App Cache\n'
    printf ' 0) Kembali ke daftar app\n'

    local c
    c="$(_wpm_menu_choice 0)"
    case "$c" in
      1)
        if confirm "Perbaiki ownership & permission file untuk '${app}'?" "default_y"; then
          acquire_lock
          tools_fix_ownership "$app"
        fi
        ;;
      2)
