    log_info "Pesan tes berhasil dikirim."
  else
    log_error "Gagal mengirim pesan tes — periksa token/chat ID/koneksi internet."
  fi
  pause_enter
}

menu_telegram() {
  while true; do
    _wpm_section "Telegram & Monitoring"
    printf '  Alert monitor  : %s\n' "$(_wpm_monitor_cron_status)"
    printf '  Bot interaktif : %s\n\n' "$(_wpm_bot_status)"
    printf ' 1) Setup bot (token + chat ID + tes)\n'
    printf ' 2) Atur threshold alert\n'
    printf ' 3) Nyalakan/matikan alert monitor\n'
    printf ' 4) Nyalakan/matikan bot interaktif\n'
    printf ' 5) Kirim tes notifikasi\n'
    printf ' 0) Kembali ke menu utama\n'

    local c
    c="$(_wpm_menu_choice 0)"
    case "$c" in
      1) menu_telegram_setup ;;
      2) menu_telegram_thresholds ;;
      3) menu_telegram_monitor_toggle ;;
      4) menu_telegram_bot_toggle ;;
      5) menu_telegram_test ;;
      0) return 0 ;;
      *) printf '%sPilihan tidak valid.%s\n' "$C_RED" "$C_RESET" ;;
    esac
  done
}

# ============================================================================
# Menu utama
# ============================================================================

main_menu() {
  while true; do
    _wpm_banner
    printf '\n'
    printf ' 1) List Web Apps\n'
    printf ' 2) Clone Web App\n'
    printf ' 3) Kelola Web App\n'
    printf ' 4) Tools\n'
    printf ' 5) Web Server Settings (OpenLiteSpeed)\n'
    printf ' 6) Telegram & Monitoring\n'
    printf ' 0) Keluar\n\n'

    local choice
    choice="$(_wpm_menu_choice 0)"
    case "$choice" in
      1) menu_list_web_apps ;;
      2)
        acquire_lock
        clone_wizard
        pause_enter
        ;;
      3) menu_manage_web_app ;;
      4) menu_tools ;;
      5) menu_webserver_settings ;;
      6) menu_telegram ;;
      0)
        printf '%sSampai jumpa.%s\n' "$C_CYAN" "$C_RESET"
        exit 0
        ;;
      *)
        printf '%sPilihan tidak valid.%s\n' "$C_RED" "$C_RESET"
        ;;
    esac
  done
}

# ============================================================================
# Entry point
# ============================================================================

main() {
  case "${1:-}" in
    --version | -v)
      printf 'wpm %s\n' "$WPM_VERSION"
      exit 0
      ;;
    --help | -h)
      printf 'Pemakaian: wpm\n\nMenjalankan menu interaktif WPM (WordPress Manager untuk OpenLiteSpeed).\nJalankan tanpa argumen sebagai root, lalu ikuti menu angka.\n'
      exit 0
      ;;
  esac

  require_root

  if [[ ! -x "$OLS_CTRL" ]]; then
    log_warn "Skrip kontrol OpenLiteSpeed tidak ditemukan di ${OLS_CTRL}. Sebagian fitur (restart, vhost) tidak akan berfungsi sampai OLS terpasang dengan benar."
  fi

  main_menu
}

main "$@"
